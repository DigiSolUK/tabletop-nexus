---
import SiteLayout from '../layouts/SiteLayout.astro';
import { siteConfig } from '../data/site-config';
import { withBasePath } from '../lib/site-path';
---

<SiteLayout
  title={`Support | ${siteConfig.appName}`}
  description={`Support, installation help, and contact details for ${siteConfig.appName}.`}
>
  <section class="panel">
    <span class="eyebrow">Support</span>
    <h2>Need help installing or recovering a profile?</h2>
    <p class="page-lead">
      Use these support surfaces for installation issues, account and sync problems, save recovery,
      or gameplay bugs. The public release is maintained as an indie desktop app and support is
      handled directly through email and the GitHub issue tracker.
    </p>
    <div class="support-links">
      <a class="button-link button-link--primary" href={`mailto:${siteConfig.supportEmail}`}>Email support</a>
      <a class="button-link" href={siteConfig.githubIssuesUrl} target="_blank" rel="noreferrer">Issue tracker</a>
      <a class="button-link" href={withBasePath('/faq')}>Read the FAQ</a>
      <a class="button-link" href={withBasePath('/downloads')}>Download installers</a>
    </div>
  </section>

  <section class="legal-card">
    <h2>What to include in a support request</h2>
    <div class="legal-stack">
      <p>Include your app version, platform, and a short description of what happened. If the problem blocks installation, include the installer filename and where you downloaded it from.</p>
      <p>For sync and profile issues, mention whether you were using offline mode or an online profile, plus whether the issue happened after switching devices.</p>
      <p>We aim to respond within 48 hours for standard support requests. Security-sensitive reports should be sent by email rather than posted publicly in the issue tracker.</p>
    </div>
  </section>
</SiteLayout>
