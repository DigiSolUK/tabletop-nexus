---
import '../styles/site.css';
import { siteConfig } from '../data/site-config';
import { withBasePath } from '../lib/site-path';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const pageTitle = title.includes(siteConfig.appName) ? title : `${title} | ${siteConfig.appName}`;
const canonicalPath = Astro.url.pathname.startsWith(import.meta.env.BASE_URL)
  ? Astro.url.pathname
  : withBasePath(Astro.url.pathname);
const canonicalUrl = new URL(canonicalPath, siteConfig.siteUrl).toString();
const ogImageUrl = new URL(withBasePath('/og.svg'), siteConfig.siteUrl).toString();
const navItems = [
  { href: withBasePath('/'), label: 'Home' },
  { href: withBasePath('/downloads'), label: 'Downloads' },
  { href: withBasePath('/games'), label: 'Games' },
  { href: withBasePath('/faq'), label: 'FAQ' },
  { href: withBasePath('/support'), label: 'Support' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="theme-color" content="#08111d" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteConfig.appName} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" type="image/svg+xml" href={withBasePath('/favicon.svg')} />
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a href={withBasePath('/')} class="brand-mark">
          <span class="brand-mark__badge">TN</span>
          <span>
            <strong>{siteConfig.appName}</strong>
            <small>Desktop gaming lounge</small>
          </span>
        </a>
        <nav class="site-nav">
          {navItems.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <div>
          <strong>{siteConfig.appName}</strong>
          <p>Offline-first board, card, and party games for polished desktop play.</p>
          <p class="site-footer__meta">
            Published by {siteConfig.companyName}. Need help? <a href={`mailto:${siteConfig.supportEmail}`}>{siteConfig.supportEmail}</a>
          </p>
        </div>
        <div class="site-footer__links">
          <a href={withBasePath('/privacy')}>Privacy</a>
          <a href={withBasePath('/terms')}>Terms</a>
          <a href={withBasePath('/system-requirements')}>System Requirements</a>
          <a href={withBasePath('/support')}>Support</a>
          <a href={siteConfig.githubRepoUrl} target="_blank" rel="noreferrer">GitHub</a>
        </div>
      </footer>
    </div>
  </body>
</html>
